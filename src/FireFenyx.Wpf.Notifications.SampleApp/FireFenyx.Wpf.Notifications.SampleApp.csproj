  <ItemGroup>
    <Content Include="Fire Fenyx logo.ico" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.1" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\FireFenyx.Wpf.Notifications\FireFenyx.Wpf.Notifications.csproj" />
    <ProjectReference Include="..\FireFenyx.Notifications.SampleApp.Shared\FireFenyx.Notifications.SampleApp.Shared.csproj" />
  </ItemGroup>
</Project>
