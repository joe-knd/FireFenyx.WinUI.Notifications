    <RootNamespace>FireFenyx.Wpf.Notifications.SampleApp</RootNamespace>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <ApplicationIcon>Fire Fenyx logo.ico</ApplicationIcon>
